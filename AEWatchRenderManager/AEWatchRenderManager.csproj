<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>..\icon\app.ico</ApplicationIcon>
  </PropertyGroup>

  <!-- Publish 時のデフォルト設定 (プロファイル未指定時のフォールバック) -->
  <!-- 通常は Properties/PublishProfiles/win-x64.pubxml を使用すること -->
  <PropertyGroup Condition="'$(PublishSingleFile)' == 'true'">
    <!-- 単一ファイルPublish時はPDBをEXEに埋め込み、余分なファイルを出さない -->
    <DebugType>embedded</DebugType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- アプリアイコン（EXE 埋め込み用＆WPF ウィンドウアイコン用） -->
    <Resource Include="..\icon\app.ico" Link="icon/app.ico"/>
  </ItemGroup>

</Project>
