<Window x:Class="AEWatchRenderManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AEWatchRenderManager"
        xmlns:vm="clr-namespace:AEWatchRenderManager.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="450" Width="800">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Grid Margin="10" AllowDrop="True" Drop="Grid_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- コントロールパネル -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
            <TextBlock Text="監視フォルダ:" VerticalAlignment="Center" Margin="5,0"/>
            <TextBox Text="{Binding MonitorPath}" Width="300" Margin="5,0"/>
            <TextBlock Text="スキャン(秒):" VerticalAlignment="Center" Margin="5,0,5,0"/>
            <TextBox Text="{Binding ScanIntervalSeconds}" Width="40" VerticalAlignment="Center" Margin="0,0,10,0" TextAlignment="Right"/>
            <Button Content="監視開始" Command="{Binding StartMonitoringCommand}" Margin="5,0" Width="80"/>
            <Button Content="監視停止" Command="{Binding StopMonitoringCommand}" Margin="5,0" Width="80"/>
        </StackPanel>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5,0,5,5">
            <TextBlock Text="移動先フォルダ:" VerticalAlignment="Center" Margin="5,0"/>
            <TextBox Text="{Binding MoveTargetPath}" Width="300" Margin="5,0"/>
            <Button Content="参照..." Command="{Binding BrowseMoveTargetCommand}" Margin="5,0" Width="60"/>
            <TextBlock Text="(リスト右クリックまたはDELキーで操作)" Foreground="Gray" VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>

        <ListView Grid.Row="2" ItemsSource="{Binding Tasks}" x:Name="taskListView" SelectionMode="Extended">
            <ListView.InputBindings>
                <KeyBinding Key="Delete" Command="{Binding DeleteTaskCommand}" CommandParameter="{Binding SelectedItems, ElementName=taskListView}"/>
            </ListView.InputBindings>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="{Binding RowBackgroundColor}"/>
                    <Setter Property="Tag" Value="{Binding DataContext, ElementName=taskListView}"/>
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu>
                                <MenuItem Header="別フォルダへ移動" Command="{Binding PlacementTarget.Tag.MoveTaskCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                <MenuItem Header="削除" Command="{Binding PlacementTarget.Tag.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="移動先フォルダへ移動" Command="{Binding MoveTaskCommand}" CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator/>
                    <MenuItem Header="ごみ箱へ削除" Command="{Binding DeleteTaskCommand}" CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ステータス" DisplayMemberBinding="{Binding StatusText}" Width="80"/>
                    <GridViewColumn Header="プロジェクト名" DisplayMemberBinding="{Binding ProjectName}" Width="200"/>
                    <GridViewColumn Header="更新日時" DisplayMemberBinding="{Binding LastUpdateTime, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="150"/>
                    <GridViewColumn Header="プロジェクトフォルダ" DisplayMemberBinding="{Binding ProjectFolderPath}" Width="320"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
