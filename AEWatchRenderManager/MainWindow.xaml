<Window x:Class="AEWatchRenderManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AEWatchRenderManager"
        xmlns:vm="clr-namespace:AEWatchRenderManager.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="600" Width="900" Icon="/icon/app.ico"
    d:DataContext="{d:DesignInstance vm:MainViewModel}">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding ScanNowCommand}"/>
    </Window.InputBindings>
    <Grid AllowDrop="True" Drop="Grid_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <Menu Grid.Row="0">
            <MenuItem Header="セットアップ(_S)">
                <MenuItem Header="監視フォルダの設定..." Command="{Binding BrowseMonitorFolderCommand}"/>
                <MenuItem Header="移動先フォルダの設定..." Command="{Binding BrowseMoveTargetCommand}"/>
            </MenuItem>
            <MenuItem Header="操作(_T)">
                <MenuItem Header="今すぐスキャン(F5)" Command="{Binding ScanNowCommand}"/>
                <MenuItem Header="スキャンサイクルの設定..." Command="{Binding SetScanCycleCommand}"/>
                <Separator/>
                <MenuItem Header="すべて選択" Command="{Binding SelectAllCommand}"/>
                <MenuItem Header="完了済みを選択" Command="{Binding SelectCompletedCommand}"/>
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="バージョン情報" Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- 操作パネル -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="10" BorderBrush="LightGray" BorderThickness="0,0,0,1">
            <Grid>
                <!-- 左側: ボタン群 + 監視状態 -->
                <StackPanel Orientation="Horizontal">
                    <Button Content="監視開始" Command="{Binding StartMonitoringCommand}" Width="100" Height="30" Margin="0,0,10,0" Background="#E3F2FD"/>
                    <Button Content="監視停止" Command="{Binding StopMonitoringCommand}" Width="100" Height="30" Margin="0,0,10,0"/>
                    <Button Content="SCAN NOW (F5)" Command="{Binding ScanNowCommand}" Width="150" Height="30" FontWeight="Bold"/>

                    <TextBlock VerticalAlignment="Center" Margin="20,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="未監視: "/>
                                <Setter Property="Foreground" Value="Gray"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMonitoring}" Value="True">
                                        <Setter Property="Text" Value="監視中: "/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding MonitorPath, Mode=OneWay}" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="Gray"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMonitoring}" Value="True">
                                        <Setter Property="Foreground" Value="Black"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- 右側: スキャン状態（スキャン完了時のみ更新） -->
                <TextBlock Text="{Binding ScanStatusText}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="Gray" FontSize="11"/>
            </Grid>
        </Border>

        <ListView Grid.Row="2" ItemsSource="{Binding TasksView}" x:Name="taskListView" SelectionMode="Extended" Margin="10">
            <ListView.InputBindings>
                <KeyBinding Key="Delete" Command="{Binding DeleteTaskCommand}" CommandParameter="{Binding SelectedItems, ElementName=taskListView}"/>
                <KeyBinding Key="F5" Command="{Binding ScanNowCommand}"/>
            </ListView.InputBindings>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Foreground" Value="{Binding RowForegroundColor}"/>
                    <Setter Property="IsSelected" Value="{Binding IsSelected}"/>
                    <Setter Property="Tag" Value="{Binding DataContext, ElementName=taskListView}"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="レンダリング情報の表示" Command="{Binding OpenRenderInfoCommand}" CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="AEPファイルの表示" Command="{Binding ShowAepFileCommand}" CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="レンダリング先を表示"
                              Command="{Binding ShowRenderDestinationCommand}"
                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              IsEnabled="{Binding PlacementTarget.SelectedItem.HasOutputPath, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator/>
                    <MenuItem Header="移動先フォルダへ移動" Command="{Binding MoveTaskCommand}" CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator/>
                    <MenuItem Header="ごみ箱へ削除" Command="{Binding DeleteTaskCommand}" CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn DisplayMemberBinding="{Binding StatusText}" Width="100">
                        <GridViewColumnHeader Content="ステータス" Tag="Status" Click="ColumnHeader_Click"/>
                    </GridViewColumn>
                    <GridViewColumn DisplayMemberBinding="{Binding ProjectName}" Width="200">
                        <GridViewColumnHeader Content="レンダリングアイテム" Tag="ProjectName" Click="ColumnHeader_Click"/>
                    </GridViewColumn>
                    <GridViewColumn DisplayMemberBinding="{Binding LastUpdateTime, StringFormat=MM/dd HH:mm:ss}" Width="120">
                        <GridViewColumnHeader Content="最終更新" Tag="LastUpdateTime" Click="ColumnHeader_Click"/>
                    </GridViewColumn>
                    <GridViewColumn DisplayMemberBinding="{Binding ProjectFolderPath}" Width="350">
                        <GridViewColumnHeader Content="パス" Tag="ProjectFolderPath" Click="ColumnHeader_Click"/>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
