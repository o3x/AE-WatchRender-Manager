<Window x:Class="AEWatchRenderManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AEWatchRenderManager"
        xmlns:vm="clr-namespace:AEWatchRenderManager.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="450" Width="800">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Grid Margin="10" AllowDrop="True" Drop="Grid_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="監視フォルダ:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Text="{Binding MonitorPath, UpdateSourceTrigger=PropertyChanged}" Width="400" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <Button Content="監視開始" Command="{Binding StartMonitoringCommand}" Width="80" Margin="0,0,10,0"/>
            <Button Content="監視停止" Command="{Binding StopMonitoringCommand}" Width="80"/>
        </StackPanel>

        <ListView Grid.Row="2" ItemsSource="{Binding Tasks}">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu>
                                <MenuItem Header="別フォルダへ移動" Command="{Binding DataContext.MoveTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                <MenuItem Header="削除" Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ステータス" DisplayMemberBinding="{Binding StatusText}" Width="80"/>
                    <GridViewColumn Header="プロジェクト名" DisplayMemberBinding="{Binding ProjectName}" Width="200"/>
                    <GridViewColumn Header="更新日時" DisplayMemberBinding="{Binding LastUpdateTime, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="150"/>
                    <GridViewColumn Header="プロジェクトフォルダ" DisplayMemberBinding="{Binding ProjectFolderPath}" Width="320"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
