<Window x:Class="AEWatchRenderManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AEWatchRenderManager"
        xmlns:vm="clr-namespace:AEWatchRenderManager.ViewModels"
        xmlns:models="clr-namespace:AEWatchRenderManager.Models"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="600" Width="900"
        MinWidth="600" MinHeight="400"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding ScanNowCommand}"/>
    </Window.InputBindings>
    <Grid AllowDrop="True" Drop="Grid_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- メニューバー -->
            <RowDefinition Height="Auto"/>  <!-- ボタン帯 -->
            <RowDefinition Height="*"/>     <!-- リスト -->
            <RowDefinition Height="Auto"/>  <!-- ステータスバー -->
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <Menu Grid.Row="0">
            <MenuItem Header="セットアップ(_S)">
                <MenuItem Header="設定..." Command="{Binding OpenSettingsCommand}"/>
            </MenuItem>
            <MenuItem Header="操作(_T)">
                <MenuItem Header="今すぐスキャン (F5)" Command="{Binding ScanNowCommand}"/>
                <Separator/>
                <MenuItem Header="監視フォルダを開く" Command="{Binding OpenMonitorFolderCommand}"
                          IsEnabled="{Binding CanStartMonitoring}"/>
                <Separator/>
                <MenuItem Header="すべて選択" Command="{Binding SelectAllCommand}"/>
                <MenuItem Header="完了済みを選択" Command="{Binding SelectCompletedCommand}"/>
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="アップデートを確認..." Command="{Binding CheckForUpdateCommand}"/>
                <Separator/>
                <MenuItem Header="バージョン情報" Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- ツールバー -->
        <Border Grid.Row="1" Padding="6,4"
                BorderBrush="{x:Static SystemColors.ControlDarkBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">

                <!-- 右端: ワーカーインジケーター（小さめ・クリック可） -->
                <Button DockPanel.Dock="Right"
                        Command="{Binding ToggleParticipationCommand}"
                        BorderThickness="1" Padding="8,4" Height="28" Margin="4,0,0,0"
                        VerticalAlignment="Center"
                        ToolTip="クリックしてワーカーを起動/停止します">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsParticipating}" Value="True">
                                    <Setter Property="BorderBrush" Value="DarkOrange"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock FontSize="11">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="○  ワーカー停止"/>
                                <Setter Property="Foreground" Value="{x:Static SystemColors.GrayTextBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsParticipating}" Value="True">
                                        <Setter Property="Text" Value="⬤  ワーカー稼働中"/>
                                        <Setter Property="Foreground" Value="DarkOrange"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <!-- 左: メイン操作ボタン群 -->
                <!-- 監視トグル: 大きめ・主役ボタン -->
                <Button Command="{Binding ToggleMonitoringCommand}" Width="150" Height="32" Margin="0,0,6,0"
                        IsEnabled="{Binding CanStartMonitoring}"
                        ToolTip="監視フォルダのスキャンを開始/停止します">
                    <TextBlock FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="▶  監視を監視"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMonitoring}" Value="True">
                                        <Setter Property="Text" Value="●  監視を監視中"/>
                                        <Setter Property="Foreground" Value="Green"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <!-- 今すぐスキャン -->
                <Button Content="今すぐスキャン" Command="{Binding ScanNowCommand}"
                        Height="28" Padding="10,0" VerticalAlignment="Center"/>

            </DockPanel>
        </Border>

        <!-- タスクリスト -->
        <Grid Grid.Row="2">
        <ListView ItemsSource="{Binding TasksView}" x:Name="taskListView" SelectionMode="Extended" Margin="10,10,10,4"
                  MouseDoubleClick="TaskListView_MouseDoubleClick">
            <ListView.InputBindings>
                <KeyBinding Key="Delete" Command="{Binding DeleteTaskCommand}" CommandParameter="{Binding SelectedItems, ElementName=taskListView}"/>
                <KeyBinding Key="F5" Command="{Binding ScanNowCommand}"/>
            </ListView.InputBindings>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <!-- Foreground は未指定（システムカラー継承）。ステータスごとに DataTrigger で上書き -->
                    <Setter Property="IsSelected" Value="{Binding IsSelected}"/>
                    <Setter Property="Tag" Value="{Binding DataContext, ElementName=taskListView}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Status}" Value="{x:Static models:RenderStatus.Rendering}">
                            <Setter Property="Foreground" Value="Green"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="{x:Static models:RenderStatus.Completed}">
                            <Setter Property="Foreground" Value="Blue"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="{x:Static models:RenderStatus.Failed}">
                            <Setter Property="Foreground" Value="Red"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="{x:Static models:RenderStatus.Suspended}">
                            <Setter Property="Foreground" Value="{x:Static SystemColors.GrayTextBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="{x:Static models:RenderStatus.Pending}">
                            <Setter Property="Foreground" Value="DarkOrange"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="レンダリング情報の表示" Command="{Binding OpenRenderInfoCommand}" CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="AEPファイルの表示" Command="{Binding ShowAepFileCommand}" CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="レンダリング先を表示"
                              Command="{Binding ShowRenderDestinationCommand}"
                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              IsEnabled="{Binding PlacementTarget.SelectedItem.HasOutputPath, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator/>
                    <MenuItem Header="移動先フォルダへ移動" Command="{Binding MoveTaskCommand}"
                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              IsEnabled="{Binding PlacementTarget.DataContext.HasMoveTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator/>
                    <MenuItem Header="ごみ箱へ削除" Command="{Binding DeleteTaskCommand}" CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator/>
                    <MenuItem Header="aerenderで参加"
                              Command="{Binding RenderWithAerenderCommand}"
                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn DisplayMemberBinding="{Binding StatusText}" Width="100">
                        <GridViewColumnHeader Content="ステータス" Tag="Status" Click="ColumnHeader_Click"/>
                    </GridViewColumn>
                    <GridViewColumn DisplayMemberBinding="{Binding ProjectName}" Width="200">
                        <GridViewColumnHeader Content="レンダリングアイテム" Tag="ProjectName" Click="ColumnHeader_Click"/>
                    </GridViewColumn>
                    <GridViewColumn DisplayMemberBinding="{Binding LastUpdateTime, StringFormat=MM/dd HH:mm:ss}" Width="120">
                        <GridViewColumnHeader Content="最終更新" Tag="LastUpdateTime" Click="ColumnHeader_Click"/>
                    </GridViewColumn>
                    <GridViewColumn DisplayMemberBinding="{Binding MachineNames}" Width="160">
                        <GridViewColumnHeader Content="参加 PC" Tag="MachineNames" Click="ColumnHeader_Click"/>
                    </GridViewColumn>
                    <GridViewColumn Width="350">
                        <GridViewColumnHeader Content="パス" Tag="DisplayPath" Click="ColumnHeader_Click"/>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayPath}" ToolTip="{Binding DisplayPathTooltip}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <!-- 出力先未確定時: 斜体 + 半透明でフォールバック表示であることを示す -->
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasOutputPath}" Value="False">
                                                    <Setter Property="FontStyle" Value="Italic"/>
                                                    <Setter Property="Opacity" Value="0.55"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
        <!-- 空リスト時のヒント -->
        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{x:Static SystemColors.GrayTextBrush}" FontSize="13"
                   IsHitTestVisible="False">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding TaskCount}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
            <Run Text="AEP をここにドロップするか、監視フォルダを設定して "/>
            <Run Text="▶ 監視を監視" FontWeight="Bold"/>
            <Run Text=" を押してください"/>
        </TextBlock>
        </Grid>

        <!-- ステータスバー: 監視状態 / 監視パス / 最終スキャン / サイクル -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="○ 未監視"/>
                            <Setter Property="Foreground" Value="{x:Static SystemColors.GrayTextBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMonitoring}" Value="True">
                                    <Setter Property="Text" Value="● 監視を監視中"/>
                                    <Setter Property="Foreground" Value="Green"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding MonitorPath}" MaxWidth="300"
                           TextTrimming="CharacterEllipsis" ToolTip="{Binding MonitorPath}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MonitorPath}" Value="">
                                    <Setter Property="Text" Value="(未設定)"/>
                                    <Setter Property="Foreground" Value="{x:Static SystemColors.GrayTextBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="最終スキャン: " Foreground="{x:Static SystemColors.GrayTextBrush}"/>
                    <TextBlock Text="{Binding LastScanText}"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="サイクル: " Foreground="{x:Static SystemColors.GrayTextBrush}"/>
                    <TextBlock Text="{Binding ScanIntervalSeconds}"/>
                    <TextBlock Text=" 秒" Foreground="{x:Static SystemColors.GrayTextBrush}"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding TaskCount}"/>
                    <TextBlock Text=" 件" Foreground="{x:Static SystemColors.GrayTextBrush}"/>
                </StackPanel>
            </StatusBarItem>
            <!-- ワーカー稼働中の処理ステータス（停止中は非表示） -->
            <StatusBarItem>
                <TextBlock Text="{Binding ParticipationStatusText}" MaxWidth="250"
                           TextTrimming="CharacterEllipsis" ToolTip="{Binding ParticipationStatusText}"
                           Foreground="DarkOrange">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsParticipating}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding UpdateNotice}" Foreground="DarkOrange" FontWeight="Bold"
                           Cursor="Hand" ToolTip="クリックしてアップデートを確認">
                    <TextBlock.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding CheckForUpdateCommand}"/>
                    </TextBlock.InputBindings>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
