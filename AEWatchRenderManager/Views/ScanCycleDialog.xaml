<Window x:Class="AEWatchRenderManager.Views.ScanCycleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="スキャンサイクルの設定"
        Width="300" Height="160"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="20,16,20,16">
        <TextBlock Text="スキャンサイクル（秒）を入力してください:" Margin="0,0,0,8" TextWrapping="Wrap"/>
        <TextBox x:Name="IntervalTextBox"
                 Width="120" HorizontalAlignment="Left"
                 MaxLength="6"
                 PreviewTextInput="IntervalTextBox_PreviewTextInput"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" Width="72" Margin="0,0,8,0" IsDefault="True" Click="OkButton_Click"/>
            <Button Content="キャンセル" Width="80" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
